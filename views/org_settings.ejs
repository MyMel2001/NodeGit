<%- include('header') %>

<div style="max-width: 600px; margin: 40px auto;">
    <div class="flex-between" style="align-items: flex-start; margin-bottom: 24px;">
        <h2 style="margin: 0;">
            <a href="/org/<%= org.name %>" style="color: var(--text-color);"><%= org.name %></a> / Settings
        </h2>
    </div>

    <div class="card" style="border-color: var(--danger-color);">
        <h3 style="color: var(--danger-color);">Danger Zone</h3>
        <p class="text-muted" style="margin-bottom: 16px;">
            Deleting an organization is irreversible. All repositories belonging to this organization will be permanently deleted.
        </p>
        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background-color: var(--danger-color); color: white; padding: 10px; border-radius: 6px; margin-bottom: 16px;">
                <%= error %>
            </div>
        <% } %>

        <form action="/org/<%= org.name %>/settings/delete" method="POST">
            <div class="form-group" style="margin-bottom: 16px;">
                <label>Verification</label>
                <div style="margin-bottom: 8px;">
                    <img src="/captcha" alt="CAPTCHA" style="border: 1px solid var(--border-color); border-radius: 4px; display: block; background: #fff;" onclick="this.src='/captcha?'+Math.random()">
                    <small class="text-muted" style="cursor: pointer;" onclick="document.querySelector('img[alt=\\'CAPTCHA\\']').src='/captcha?'+Math.random()">Click image to refresh</small>
                </div>
                <input type="text" name="captcha" class="form-control" placeholder="Enter characters above" required>
            </div>
            <button type="submit" class="btn" style="background-color: var(--danger-color); color: white; width: 100%;" onclick="return confirm('Are you absolutely sure you want to delete this organization? This action cannot be undone and will delete ALL repositories within the organization.');">Delete Organization</button>
        </form>
    </div>
</div>

<%- include('footer') %>
