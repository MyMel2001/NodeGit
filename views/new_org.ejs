<%- include('header') %>

<div style="max-width: 400px; margin: 40px auto;">
    <h2 style="text-align: center; margin-bottom: 24px;">Create Organization</h2>
    
    <% if (error) { %>
        <div style="background-color: var(--danger-color); color: white; padding: 10px; border-radius: 6px; margin-bottom: 16px;">
            <%= error %>
        </div>
    <% } %>

    <div class="card">
        <form action="/org/new" method="POST">
            <div class="form-group">
                <label for="orgname">Organization Name</label>
                <input type="text" id="orgname" name="orgname" class="form-control" required autofocus>
                <p class="text-muted" style="font-size: 0.85rem; margin-top: 8px;">
                    This will be the namespace for your organization's repositories (e.g. <code>NodeGit/my-repo</code>).
                </p>
            </div>
            
            <div class="form-group" style="margin-top: 16px;">
                <label>Verification</label>
                <div style="margin-bottom: 8px;">
                    <img src="/captcha" alt="CAPTCHA" style="border: 1px solid var(--border-color); border-radius: 4px; display: block; background: #fff;" onclick="this.src='/captcha?'+Math.random()">
                    <small class="text-muted" style="cursor: pointer;" onclick="document.querySelector('img[alt=\\'CAPTCHA\\']').src='/captcha?'+Math.random()">Click image to refresh</small>
                </div>
                <input type="text" name="captcha" class="form-control" placeholder="Enter characters above" required>
            </div>
            
            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 24px;">Create Organization</button>
        </form>
    </div>
</div>

<%- include('footer') %>
