<%- include('header') %>

<div style="max-width: 600px; margin: 0 auto;">
    <h2>Import repositories from GitHub</h2>
    <p class="text-muted" style="margin-bottom: 24px;">
        Connect your GitHub account to clone your public repositories into NodeGit.
    </p>

    <% if (error) { %>
        <div style="background-color: var(--danger-color); color: white; padding: 10px; border-radius: 6px; margin-bottom: 16px;">
            <%= error %>
        </div>
    <% } %>

    <% if (success) { %>
        <div style="background-color: var(--success-color); color: white; padding: 10px; border-radius: 6px; margin-bottom: 16px;">
            <%= success %>
        </div>
    <% } %>

    <div class="card">
        <form action="/import" method="POST" id="import-form">
            <div class="form-group">
                <label for="githubUsername">GitHub Username or Organization</label>
                <input type="text" id="githubUsername" name="githubUsername" class="form-control" placeholder="e.g. google or torvalds" autofocus>
                <p class="text-muted" style="font-size: 0.85rem; margin-top: 8px;">
                    Required for public repositories if no token is provided.
                </p>
            </div>

            <div class="form-group" style="margin-top: 24px;">
                <label for="githubToken">GitHub Personal Access Token (Optional for public repos)</label>
                <input type="password" id="githubToken" name="githubToken" class="form-control" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx">
                <p class="text-muted" style="font-size: 0.85rem; margin-top: 8px;">
                    Required only for <strong>private</strong> repositories or to list all your own repos.
                </p>
            </div>

            <hr style="margin: 24px 0; border: 0; border-top: 1px solid var(--border-color);">

            <button type="submit" class="btn btn-primary" id="import-btn">Import Repositories</button>
        </form>
    </div>

    <script>
        document.getElementById('import-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const btn = document.getElementById('import-btn');
            const form = e.target;
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span> Importing...';
            
            // Create or clear status container
            let statusContainer = document.getElementById('import-status');
            if (!statusContainer) {
                statusContainer = document.createElement('div');
                statusContainer.id = 'import-status';
                statusContainer.style.marginTop = '24px';
                form.parentNode.appendChild(statusContainer);
            }
            statusContainer.innerHTML = '<p class="text-muted">Initializing connection...</p>';

            try {
                const response = await fetch('/import', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let buffer = '';

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;
                    
                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n');
                    buffer = lines.pop();

                    for (const line of lines) {
                        if (!line.trim() || line.startsWith(':')) continue;
                        
                        try {
                            const update = JSON.parse(line);
                            renderUpdate(update, statusContainer);
                        } catch (e) {
                            console.error('Error parsing update:', e, line);
                        }
                    }
                }
            } catch (err) {
                statusContainer.innerHTML = `<div style="background-color: var(--danger-color); color: white; padding: 10px; border-radius: 6px;">Error: ${err.message}</div>`;
                btn.disabled = false;
                btn.innerHTML = 'Import Repositories';
            }
        });

        function renderUpdate(update, container) {
            const btn = document.getElementById('import-btn');
            
            if (update.status === 'fetching' || update.status === 'starting' || update.status === 'cloning' || update.status === 'skipping') {
                let progressHtml = '';
                if (update.total) {
                    const percent = Math.round(((update.current || 0) / update.total) * 100);
                    progressHtml = `
                        <div style="width: 100%; background-color: var(--border-color); height: 8px; border-radius: 4px; margin: 12px 0; overflow: hidden;">
                            <div style="width: ${percent}%; background-color: var(--success-color); height: 100%; transition: width 0.3s ease;"></div>
                        </div>
                        <p style="font-size: 0.85rem; margin-bottom: 8px;">Progress: ${update.current || 0} / ${update.total} repositories</p>
                    `;
                }
                
                container.innerHTML = `
                    <div class="card" style="background-color: var(--bg-color); border-color: var(--border-color); padding: 16px;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <span class="spinner" style="border-top-color: var(--primary-color);"></span>
                            <strong>${update.message}</strong>
                        </div>
                        ${progressHtml}
                    </div>
                `;
            } else if (update.status === 'done') {
                container.innerHTML = `
                    <div style="background-color: var(--success-color); color: white; padding: 10px; border-radius: 6px; margin-bottom: 16px;">
                        ${update.message}
                    </div>
                    <p style="text-align: center; margin-top: 16px;">
                        <a href="/" class="btn">Go to Dashboard</a>
                    </p>
                `;
                btn.innerHTML = 'Import Complete';
            } else if (update.status === 'error') {
                container.innerHTML = `
                    <div style="background-color: var(--danger-color); color: white; padding: 10px; border-radius: 6px;">
                        Error: ${update.error}
                    </div>
                `;
                btn.disabled = false;
                btn.innerHTML = 'Retry Import';
            }
        }
    </script>

    <div class="card" style="margin-top: 24px; background-color: var(--bg-color); border-style: dashed;">
        <h3 style="font-size: 1rem; margin-bottom: 8px;">How it works</h3>
        <p class="text-muted" style="font-size: 0.9rem;">
            1. Provide your GitHub Personal Access Token.<br>
            2. We fetch a list of your public repositories.<br>
            3. We perform a <code>git clone --mirror</code> for each repository into your NodeGit account.<br>
            4. Your code history and branches are preserved.
        </p>
    </div>
</div>

<%- include('footer') %>
