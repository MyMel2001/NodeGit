<%- include('header') %>

<div class="flex-between" style="align-items: flex-start; margin-bottom: 16px;">
    <div>
        <h2 style="margin-bottom: 4px;">
            <a href="/<%= owner %>"><%= owner %></a> / 
            <a href="/<%= owner %>/<%= repo %>" style="font-weight: 700;"><%= repo %></a>
        </h2>
    </div>
</div>

<div style="margin-bottom: 24px; border-bottom: 1px solid var(--border-color); display: flex; gap: 24px;">
    <a href="/<%= owner %>/<%= repo %>" style="padding: 8px 0; color: var(--fg-color);">Code</a>
    <a href="/<%= owner %>/<%= repo %>/pulls" style="padding: 8px 0; border-bottom: 2px solid var(--primary-color); font-weight: 600;">Pull Requests</a>
</div>

<div class="flex-between" style="margin-bottom: 24px;">
    <h3><%= pulls.length %> Pull Requests</h3>
    <a href="/<%= owner %>/<%= repo %>/pull/new" class="btn btn-primary">New Pull Request</a>
</div>

<% if (pulls.length === 0) { %>
    <div class="card" style="text-align: center; padding: 48px;">
        <p class="text-muted">There aren't any open pull requests.</p>
    </div>
<% } else { %>
    <ul class="repo-list">
        <% pulls.forEach(pr => { %>
            <li>
                <div class="flex-between">
                    <div>
                        <a href="/<%= owner %>/<%= repo %>/pull/<%= pr.id %>" style="font-size: 1.1rem; font-weight: 600;">
                            <%= pr.value.title %>
                        </a>
                        <p class="text-muted" style="margin-top: 4px; font-size: 0.85rem;">
                            #<%= pr.id.split('_').pop() %> opened on <%= new Date(pr.value.createdAt).toLocaleDateString() %> by <%= pr.value.author %>
                            • Status: <span style="font-weight: 600; color: <%= pr.value.status === 'merged' ? 'var(--success-color)' : 'var(--primary-color)' %>"><%= pr.value.status.toUpperCase() %></span>
                        </p>
                    </div>
                </div>
            </li>
        <% }); %>
    </ul>
<% } %>

<%- include('footer') %>
